#!/usr/bin/env python3
"""
opsaxiom-fsnapshot —— snapshot 型回滚的 mock（H-7 依赖）。

fsck/修复类操作前必须先有块级快照，回滚 = 恢复快照（docs/02 §snapshot）。
真机上是 LVM/存储快照，sim 里作用于受 OPSAXIOM_FSNAPSHOT_ROOT 约束的
文件级快照存储，从而无需真块设备就能验证"先快照 → 操作改动数据 →
恢复快照后数据与快照时逐字节一致"。

子命令：
  snap <file>         把 <file> 内容快照到快照存储（按绝对路径散列命名）
  restore <file>      从快照存储恢复 <file>（快照不存在则退出码 1）
  has <file>          有快照则打印 yes 退出 0，否则 no 退出 1
"""
import hashlib
import os
import pathlib
import sys

ROOT = pathlib.Path(os.environ.get("OPSAXIOM_FSNAPSHOT_ROOT", "/tmp/opsaxiom-fsnapshot"))


def _slot(target):
    h = hashlib.sha256(str(pathlib.Path(target).resolve()).encode()).hexdigest()[:16]
    return ROOT / f"{h}.snap"


def main(argv):
    if len(argv) < 2:
        print("用法：opsaxiom-fsnapshot snap|restore|has <file>", file=sys.stderr)
        return 2
    ROOT.mkdir(parents=True, exist_ok=True)
    cmd, target = argv[0], pathlib.Path(argv[1])
    slot = _slot(target)
    if cmd == "snap":
        slot.write_bytes(target.read_bytes())
        print(f"snap {target} → {slot.name}")
        return 0
    if cmd == "restore":
        if not slot.exists():
            print(f"无快照可恢复：{target}", file=sys.stderr)
            return 1
        target.write_bytes(slot.read_bytes())
        print(f"restore {target} ← {slot.name}")
        return 0
    if cmd == "has":
        print("yes" if slot.exists() else "no")
        return 0 if slot.exists() else 1
    print(f"未知子命令 {cmd}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

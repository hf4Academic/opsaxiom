#!/usr/bin/env python3
"""
opsaxiom —— OpsAxiom 运行时 CLI（导航档 MVP，T-1）。

  opsaxiom run <skill-id> [--param k=v]... [--real] [--answers <file>]
      交互式（或脚本驱动）走一个 Skill 的排查/变更决策树，导航档语义：
      只出方案与变更简报，人执行一切命令，逐步判读放行。
  opsaxiom diagnose "<症状>"        （T-2 实现）

--answers <file>：YAML，非交互驱动（测试/演示）：
  mode: guided|real
  params: {mount: "/"}
  answers: {<node_id>: <粘贴的命令输出 / 选项序号 / y|n>}
"""
import argparse
import os
import pathlib
import sys

ROOT = pathlib.Path(__file__).resolve().parents[2]
sys.path.insert(0, str(ROOT / "tools"))
import yaml            # noqa: E402
import runtime         # noqa: E402


def _find_skill(skill_id):
    for p in (ROOT / "skills").rglob("skill.yaml"):
        s = yaml.safe_load(p.read_text(encoding="utf-8"))
        if s.get("metadata", {}).get("id") == skill_id:
            return p, s
    return None, None


def _badge(maturity):
    return {"draft": "⚪draft", "sim_verified": "🔵sim", "field_verified": "🟢field",
            "certified": "🟡cert"}.get(maturity, maturity)


def cmd_run(args):
    p, s = _find_skill(args.skill)
    if not p:
        print(f"找不到 Skill: {args.skill}", file=sys.stderr)
        return 2
    params = dict(kv.split("=", 1) for kv in (args.param or []))
    mode = "guided"
    answers = None
    if args.answers:
        a = yaml.safe_load(pathlib.Path(args.answers).read_text(encoding="utf-8"))
        mode = a.get("mode", "guided")
        params = {**(a.get("params") or {}), **params}
        answers = a.get("answers") or {}
    if args.real:
        mode = "real"
    meta = s["metadata"]
    io = runtime.IO(answers=answers, echo=True)
    sid = args.sid or f"{args.skill.replace('.', '_')}-run"
    sess = runtime.Session(p, params=params, mode=mode, io=io, sid=sid)
    start = None
    if args.resume:
        start = sess.load_state()
        if not start:
            print(f"无可续跑的会话状态：{sid}", file=sys.stderr)
            return 2
        print(f"OpsAxiom · {meta['name']}  [{_badge(meta['maturity'])}]  ⏪ 续跑，从节点 {start} 恢复")
    else:
        print(f"OpsAxiom · {meta['name']}  [{_badge(meta['maturity'])}]  模式={sess.mode}")
        print(f"（导航档：Agent 只出方案与变更简报，写操作由你亲自执行）")
    res = sess.run(start=start)
    print(f"\n审计已记录：{res['audit_file']}")
    if res["outcome"] == "quit":
        print(f"会话中断，进度已存。续跑： opsaxiom run {args.skill} --sid {sid} --resume")
    return 0


def main():
    ap = argparse.ArgumentParser(prog="opsaxiom")
    sub = ap.add_subparsers(dest="cmd")          # W-1：无子命令→进 REPL
    rp = sub.add_parser("run", help="走一个 Skill 的决策树")
    rp.add_argument("skill")
    rp.add_argument("--param", action="append")
    rp.add_argument("--real", action="store_true", help="只读命令自动执行")
    rp.add_argument("--answers", help="脚本驱动的答案文件")
    rp.add_argument("--sid", help="会话 id")
    rp.add_argument("--resume", action="store_true", help="从上次中断处续跑（需配 --sid）")
    rp.set_defaults(fn=cmd_run)
    try:
        from opsaxiom_diagnose import add_diagnose  # T-2
        add_diagnose(sub)
    except Exception:
        pass
    try:
        from doctor import add_doctor  # V-1
        add_doctor(sub)
    except Exception:
        pass
    try:
        from capture_cli import add_capture  # V-2
        add_capture(sub)
    except Exception:
        pass
    try:
        from hub_cli import add_hub  # V-4
        add_hub(sub)
    except Exception:
        pass
    try:
        from model_cli import add_model  # M-2 模型配置
        add_model(sub)
    except Exception:
        pass
    try:
        from incident_cli import add_incident  # N-1 取证式诊断（机器可读）
        add_incident(sub)
    except Exception:
        pass
    try:
        from target_cli import add_target  # I-2/I-3 设备接入
        add_target(sub)
    except Exception:
        pass
    try:
        from cred_cli import add_cred  # I-6 本地凭证管理
        add_cred(sub)
    except Exception:
        pass
    # N-3 入口策略：pi 智能入口优先，Python REPL 零依赖兜底（R3 不破）
    import sys as _sys
    argv1 = _sys.argv[1] if len(_sys.argv) > 1 else None
    if argv1 == "classic":                       # 强制老 REPL
        import repl
        return repl.start()
    if argv1 == "pi":                            # 强制 pi 入口
        import pi_entry
        gap = pi_entry.launch(ROOT, _sys.argv[2:])
        print(f"pi 入口不可用：{gap}", file=_sys.stderr)
        return 2
    args = ap.parse_args()
    if not getattr(args, "cmd", None):           # 裸敲 opsaxiom
        if _sys.stdin.isatty() and os.environ.get("OPSAXIOM_ENTRY") != "classic":
            import pi_entry
            if pi_entry.probe()[0]:
                pi_entry.launch(ROOT)            # exec，不返回
        import repl                              # 兜底：老 REPL（气隙/无 node 无感）
        return repl.start()
    return args.fn(args)


if __name__ == "__main__":
    sys.exit(main())
